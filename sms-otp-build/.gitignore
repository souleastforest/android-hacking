# Git ignore for sms-otp-build

# Android build outputs
companion-app/.gradle/
companion-app/build/
companion-app/app/build/
companion-app/local.properties
companion-app/.idea/
companion-app/*.iml
companion-app/captures/

# KSU module - don't track compiled APK (generated by build.sh)
ksu-module/system/priv-app/SmsOtpCompanion/SmsOtpCompanion.apk

# Build output zips
build/*.zip

# macOS
.DS_Store
**/.DS_Store

# Logs
*.log

# Keystore (never commit real keystores)
*.jks
*.keystore
!debug.keystore
